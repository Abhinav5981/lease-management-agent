# ── Required ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your key before running docker-compose.
#
#   cp .env.example .env
#
# Get a FREE Groq API key at: https://console.groq.com
# No credit card required.

GROQ_API_KEY=gsk_...

# ── Optional overrides ───────────────────────────────────────────────────────
# docker-compose.yml overrides DATABASE_URL and QDRANT_URL automatically.
# These values are used for local development without Docker.

GROQ_MODEL=llama-3.3-70b-versatile
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

DATABASE_URL=postgresql+asyncpg://lease_user:lease_pass@localhost:5432/lease_db

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=lease_knowledge

DEBUG=false
